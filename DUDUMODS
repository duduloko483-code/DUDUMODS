#!/data/data/com.termux/files/usr/bin/bash

clear

# =========================================
# CORES
# =========================================
RED='\033[1;31m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
CYAN='\033[1;36m'
WHITE='\033[1;37m'
NC='\033[0m'

# =========================================
# BANNER
# =========================================

echo -e "${CYAN}"
echo "██╗  ██╗██╗   ██╗██████╗ ██╗   ██╗"
echo "██║ ██╔╝██║   ██║██╔══██╗██║   ██║"

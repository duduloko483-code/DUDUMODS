#!/data/data/com.termux/files/usr/bin/bash

clear

RED='\033[1;31m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
CYAN='\033[1;36m'
NC='\033[0m'

echo -e "${CYAN}"
echo "======================================="
echo "         DUDU MODS SCANNER"
echo "======================================="
echo -e "${NC}"

sleep 1

suspeito=0

echo -e "${YELLOW}[•] Verificando root...${NC}"

if command -v su >/dev/null 2>&1; then
    echo -e "${RED}[ROOT DETECTADO]${NC}"
    suspeito=1
else
    echo -e "${GREEN}[SEM ROOT]${NC}"
fi

echo ""
echo -e "${YELLOW}[•] Verificando depuração Wi-Fi...${NC}"

wifi=$(settings get global adb_wifi_enabled 2>/dev/null)

if [ "$wifi" = "1" ]; then
    echo -e "${RED}[DEPURAÇÃO WIFI ATIVA]${NC}"
    suspeito=1
else
    echo -e "${GREEN}[DEPURAÇÃO WIFI DESATIVADA]${NC}"
fi

echo ""
echo -e "${YELLOW}[•] Dispositivos ADB:${NC}"
adb devices 2>/dev/null

echo ""
echo -e "${YELLOW}[•] Verificando apps suspeitos...${NC}"

apps="
com.cheatengine
com.luckypatcher
org.sbgamehacker
"

for pkg in $apps; do
    if pm list packages | grep -q "$pkg"; then
        echo -e "${RED}[APP SUSPEITO] $pkg${NC}"
        suspeito=1
    fi
done

echo ""
echo -e "${YELLOW}[•] Verificando pasta MReplays...${NC}"

BASE="/storage/emulated/0/Android/data/com.dts.freefireth/files/MReplays"

if [ -d "$BASE" ]; then
    echo -e "${GREEN}[PASTA ENCONTRADA]${NC}"
else
    echo -e "${RED}[PASTA NÃO ENCONTRADA]${NC}"
fi

echo ""
echo -e "${YELLOW}[•] Informações do aparelho${NC}"

echo "ANDROID : $(getprop ro.build.version.release)"
echo "MODELO  : $(getprop ro.product.model)"
echo "MARCA   : $(getprop ro.product.brand)"

echo ""

if [ $suspeito -eq 1 ]; then
    echo -e "${RED}"
    echo "======== STATUS: SUSPEITO ========"
    echo -e "${NC}"
else
    echo -e "${GREEN}"
    echo "========== STATUS: LIMPO =========="
    echo -e "${NC}"
fi

echo ""
echo "============== FIM =============="

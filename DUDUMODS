echo "██╔═██╗ ██║   ██║██╔══██╗██║   ██║"
echo "██║  ██╗╚██████╔╝██║  ██║╚██████╔╝"
echo "╚═╝  ╚═╝ ╚═════╝ ╚═╝  ╚═╝ ╚═════╝ "
echo ""
echo "        DUDU MODS SCANNER"
echo -e "${NC}"

sleep 1

# =========================================
# LOADING
# =========================================

echo -e "${GREEN}[✓] Identificando aparelho e ambiente...${NC}"
sleep 1

echo -e "${GREEN}[✓] Verificando integridade de logs...${NC}"
sleep 1

echo -e "${GREEN}[✓] Verificando root e ferramentas suspeitas...${NC}"
sleep 1

echo -e "${GREEN}[✓] Verificando horário e uptime...${NC}"
sleep 1

echo -e "${GREEN}[✓] Verificando ambiente e clipboard...${NC}"
sleep 1

echo -e "${GREEN}[✓] Analisando MReplays...${NC}"
sleep 1

echo -e "${GREEN}[✓] Checando silenciamento de logcat...${NC}"
sleep 1

echo -e "${GREEN}[✓] Checando manipulação de bateria...${NC}"
sleep 1

echo -e "${GREEN}[✓] Checando bypass de wallhack/holograma...${NC}"
sleep 1

echo -e "${GREEN}[✓] Checando shaders...${NC}"
sleep 1

echo -e "${GREEN}[✓] Checando OBB...${NC}"
sleep 1

echo -e "${GREEN}[✓] Checando depuração Wi-Fi...${NC}"
sleep 1

# =========================================
# DEPURAÇÃO WIFI
# =========================================

wifi_debug=0

if settings get global adb_wifi_enabled 2>/dev/null | grep -q "1"; then
    wifi_debug=1
fi

# =========================================
# PASTA REPLAY
# =========================================

BASE="/storage/emulated/0/Android/data/com.dts.freefireth/files/MReplays"

latest_bin=$(ls -1 "$BASE"/*.bin 2>/dev/null | tail -1)

folder_alert=0
bin_alert=0

if [ -f "$latest_bin" ]; then

folder_modify=$(stat -c %y "$BASE")
folder_change=$(stat -c %z "$BASE")

bin_access=$(stat -c %x "$latest_bin")
bin_modify=$(stat -c %y "$latest_bin")
bin_change=$(stat -c %z "$latest_bin")

if [ "$folder_modify" != "$bin_modify" ] || [ "$folder_change" != "$bin_change" ]; then
    folder_alert=1
fi

if [ "$bin_access" != "$bin_modify" ] || [ "$bin_modify" != "$bin_change" ]; then
    bin_alert=1
fi

fi

# =========================================
# STATUS
# =========================================

suspeito=0

if [ $folder_alert -eq 1 ] || [ $bin_alert -eq 1 ] || [ $wifi_debug -eq 1 ]; then
    suspeito=1
fi

clear

echo -e "${CYAN}"
echo "╔══════════════════════════════════════╗"
echo "║          DUDU MODS SCANNER          ║"
echo "╚══════════════════════════════════════╝"
echo -e "${NC}"

echo ""

if [ $suspeito -eq 1 ]; then
    echo -e "${RED}"
    echo "███████╗██╗   ██╗███████╗██████╗ ███████╗██╗████████╗ ██████╗ "
    echo "██╔════╝██║   ██║██╔════╝██╔══██╗██╔════╝██║╚══██╔══╝██╔═══██╗"
    echo "███████╗██║   ██║███████╗██████╔╝█████╗  ██║   ██║   ██║   ██║"
    echo "╚════██║██║   ██║╚════██║██╔═══╝ ██╔══╝  ██║   ██║   ██║   ██║"
    echo "███████║╚██████╔╝███████║██║     ███████╗██║   ██║   ╚██████╔╝"
    echo "╚══════╝ ╚═════╝ ╚══════╝╚═╝     ╚══════╝╚═╝   ╚═╝    ╚═════╝ "
    echo -e "${NC}"
else
    echo -e "${GREEN}"
    echo "██╗     ██╗███╗   ███╗██████╗  ██████╗ "
    echo "██║     ██║████╗ ████║██╔══██╗██╔═══██╗"
    echo "██║     ██║██╔████╔██║██████╔╝██║   ██║"
    echo "██║     ██║██║╚██╔╝██║██╔═══╝ ██║   ██║"
    echo "███████╗██║██║ ╚═╝ ██║██║     ╚██████╔╝"
    echo "╚══════╝╚═╝╚═╝     ╚═╝╚═╝      ╚═════╝ "
    echo -e "${NC}"
fi

echo ""
echo "================= RESULTADO ================="
echo ""

if [ $wifi_debug -eq 1 ]; then
    echo -e "${RED}🚨 DEPURACAO WIFI ATIVADA 🚨${NC}"
fi

if [ $folder_alert -eq 1 ]; then
    echo -e "${RED}🚨 DIVERGENCIA NA PASTA MREPLAYS 🚨${NC}"
fi

if [ $bin_alert -eq 1 ]; then
    echo -e "${RED}🚨 BIN MODIFICADO / ACESSADO 🚨${NC}"
fi

if [ $suspeito -eq 0 ]; then
    echo -e "${GREEN}✅ NENHUMA INCONSISTENCIA DETECTADA ✅${NC}"
fi

echo ""
echo "================= INFO ================="
echo ""

echo "ANDROID : $(getprop ro.build.version.release)"
echo "MODELO  : $(getprop ro.product.model)"
echo "MARCA   : $(getprop ro.product.brand)"

echo ""
echo "================= DISPOSITIVOS ADB ================="
adb devices 2>/dev/null

echo ""
echo "================= FIM DO SCAN ================="
echo ""
